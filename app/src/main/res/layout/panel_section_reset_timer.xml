<?xml version="1.0" encoding="utf-8"?>
<!-- Phase 9E: Server Reset Countdown — compact collapsible strip -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/section_reset_timer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Header: "Server Resets ▸" — single tappable line, always visible -->
    <LinearLayout
        android:id="@+id/reset_timer_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <TextView
            android:id="@+id/reset_timer_header_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/panel_section_reset_timer"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:alpha="0.75" />

        <TextView
            android:id="@+id/reset_timer_expand_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="▸"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:alpha="0.75" />

    </LinearLayout>

    <!-- Expanded content: single inline text row, default GONE (collapsed) -->
    <HorizontalScrollView
        android:id="@+id/reset_timer_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/reset_timer_inline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:fontFamily="monospace" />

    </HorizontalScrollView>

</LinearLayout>
