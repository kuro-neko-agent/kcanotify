<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimaryDark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:divider="@drawable/divider_section"
        android:showDividers="middle"
        android:dividerPadding="3dp">

        <!-- Section 0: HQ Info bar -->
        <include layout="@layout/panel_section_hq_info" />

        <!-- Section 1: Resource overview -->
        <include layout="@layout/panel_section_resource" />

        <!-- Section 2: Server reset countdown (Phase 9E) -->
        <include layout="@layout/panel_section_reset_timer" />

        <!-- Section 3: Fleet info (compact for split-pane) -->
        <include layout="@layout/panel_section_fleet_compact" />

        <!-- Section 4: Dock/Construction/Expedition timers (Phase 9D) -->
        <include layout="@layout/panel_section_docks" />

        <!-- Section 5: Quest tracking -->
        <include layout="@layout/panel_section_quest_track" />

    </LinearLayout>
</ScrollView>
