<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/overlay_background">

    <FrameLayout
        android:id="@+id/battle_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Placeholder shown when no battle data -->
        <TextView
            android:id="@+id/battle_no_data_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/panel_no_battle_data"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:visibility="visible" />

        <!-- Battle content will be programmatically injected here -->
        <FrameLayout
            android:id="@+id/battle_content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </FrameLayout>
</ScrollView>
