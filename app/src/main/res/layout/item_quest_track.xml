<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!-- Category color bar -->
    <View
        android:id="@+id/quest_track_category_bar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="4dp"
        android:layout_marginRight="4dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Title row: [type badge] [title] [progress] -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Type badge (D/W/M/Q/Y) -->
            <TextView
                android:id="@+id/quest_track_type_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="3dp"
                android:paddingEnd="3dp"
                android:paddingLeft="3dp"
                android:paddingRight="3dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:layout_marginEnd="4dp"
                android:layout_marginRight="4dp"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:gravity="center" />

            <!-- Quest title -->
            <TextView
                android:id="@+id/quest_track_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="11sp" />

            <!-- Progress indicator -->
            <TextView
                android:id="@+id/quest_track_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:textSize="10sp"
                android:singleLine="true" />

            <!-- Expand/collapse chevron -->
            <TextView
                android:id="@+id/quest_track_expand_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▸"
                android:textColor="#88FFFFFF"
                android:textSize="10sp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp" />
        </LinearLayout>

        <!-- Sub-goal breakdown (hidden by default) -->
        <TextView
            android:id="@+id/quest_track_subgoals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingLeft="24dp"
            android:textColor="#AAAAAA"
            android:textSize="9sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:visibility="gone" />

        <!-- Expandable detail section (hidden by default) -->
        <LinearLayout
            android:id="@+id/quest_track_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingEnd="4dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <!-- Quest description -->
            <TextView
                android:id="@+id/quest_track_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp"
                android:paddingBottom="4dp" />

            <!-- Per-condition progress breakdown container (children added programmatically) -->
            <LinearLayout
                android:id="@+id/quest_track_cond_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Type label (Daily/Weekly/etc.) -->
            <TextView
                android:id="@+id/quest_track_type_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAFFFFFF"
                android:textSize="9sp"
                android:paddingTop="2dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
