<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/section_resource"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Clickable header -->
    <LinearLayout
        android:id="@+id/section_resource_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Resources"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/section_resource_arrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_arrow_up"
            app:srcCompat="@drawable/ic_arrow_up" />
    </LinearLayout>

    <!-- Collapsible content: 2 rows x 4 columns -->
    <GridLayout
        android:id="@+id/section_resource_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:padding="4dp"
        android:useDefaultMargins="true">

        <!-- Row 1: Fuel, Ammo, Steel, Bauxite -->
        <TextView
            android:id="@+id/res_fuel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:drawablePadding="2dp"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/res_ammo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:drawablePadding="2dp"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/res_steel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:drawablePadding="2dp"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/res_bauxite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:drawablePadding="2dp"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <!-- Row 2: Instant Build, Instant Repair, DevMat, ScrewMat -->
        <TextView
            android:id="@+id/res_instant_build"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/res_instant_repair"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/res_dev_material"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/res_screw"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="11sp" />
    </GridLayout>
</LinearLayout>
